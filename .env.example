# Set VITE_AI_ENABLED=true only when /api/ai is reachable (i.e. deployed to Vercel
# with GROQ_API_KEY set, or running `vercel dev` locally). In pure `vite dev`
# mode, keep this unset — the app falls back to its deterministic parser and
# still runs full backtests.
VITE_AI_ENABLED=false

# Server-side only. Set in Vercel project settings (production + preview).
GROQ_API_KEY=
